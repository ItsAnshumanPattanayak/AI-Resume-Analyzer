# Copy this file to .env.docker and replace every placeholder.
# Generate a JWT secret with:
# python -c "import secrets; print(secrets.token_urlsafe(64))"

POSTGRES_DB=resume_analyzer
POSTGRES_USER=resume_user
POSTGRES_PASSWORD=replace-with-a-strong-unique-database-password

JWT_SECRET_KEY=replace-with-a-generated-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
