# Railway supplies service variables through the runtime environment.
# Do not copy real credentials into this file or commit a production .env.

APP_NAME=AI Resume Analyzer API
APP_VERSION=1.5.0
APP_ENVIRONMENT=production
DEBUG=false

# Set this in Railway as a reference to the managed PostgreSQL service's
# private DATABASE_URL. Do not use DATABASE_PUBLIC_URL for the deployed API.
DATABASE_URL=postgresql://<user>:<password>@<private-host>:5432/<database>
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800

# Generate a unique value, for example with:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=<generate-a-unique-random-secret-at-least-32-characters>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Use the exact deployed frontend HTTPS origin, without a trailing slash.
CORS_ORIGINS=https://<frontend-public-domain>
ALLOW_LOCALHOST_ORIGIN_REGEX=false

MAXIMUM_FILE_SIZE_MB=5

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REGISTRATION_REQUESTS=5
RATE_LIMIT_LOGIN_REQUESTS=10
RATE_LIMIT_RESUME_REQUESTS=10

SEMANTIC_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
SEMANTIC_MODEL_LOCAL_ONLY=false
# Optionally attach a Railway volume and set HF_HOME to its mount path.
HF_HOME=/app/model_cache

LOG_LEVEL=INFO
